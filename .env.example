# ── Identity ────────────────────────────────────────────────────────────────
YOUR_NAME="Jane Doe"
YOUR_EMAIL="jane@example.com"

# ── Cloudflare Pages ─────────────────────────────────────────────────────────
# Get these from dash.cloudflare.com → Workers & Pages → D1
CF_ACCOUNT_ID=
CF_API_TOKEN=
D1_DATABASE_ID=
JWT_SECRET=                        # any random 32+ char string

# ── Resume engine ────────────────────────────────────────────────────────────
# Path to your resume-engine folder (contains Memory/experience.md etc.)
RESUME_ENGINE_PATH=./resume-engine

# ── Tailor sidecar ───────────────────────────────────────────────────────────
# Where compiled resumes are saved (can be an external drive)
TAILOR_OUT_ROOT=./output/tailored-resumes

# Ollama model to use for resume tailoring (must be pulled locally)
# Recommended: gemma3:12b  (qwen3 truncates under JSON schema)
OLLAMA_MODEL=gemma3:12b
OLLAMA_HOST=127.0.0.1

# Shared secret between the sidecar and the app (make it random)
TAILOR_TOKEN=

# Public cloudflared tunnel URL → localhost:8787  (optional, for remote access)
# TAILOR_ORIGIN=https://tailor-relay.yourdomain.com

# ── Job pipeline ─────────────────────────────────────────────────────────────
# LinkedIn credentials for scraping (stored locally, never sent anywhere)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Tracker API (optional) ───────────────────────────────────────────────────
# TRACKER_API_URL=
# TRACKER_API_TOKEN=
