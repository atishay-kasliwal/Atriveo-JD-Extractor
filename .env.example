# ── Identity ────────────────────────────────────────────────────────────────
YOUR_NAME="Jane Doe"
YOUR_EMAIL="jane@example.com"

# ── Backend API ──────────────────────────────────────────────────────────────
# Secret key that authenticates requests from the UI to your backend.
# Generate with: openssl rand -hex 32
API_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
# sqlite (default, no setup), postgres, or mongo
DB_TYPE=sqlite
# MONGO_URI=mongodb://localhost:27017/atriveo
# POSTGRES_URL=postgresql://user:pass@localhost:5432/atriveo

# ── Resume engine ────────────────────────────────────────────────────────────
# Path to your resume-engine folder (contains Memory/experience.md etc.)
RESUME_ENGINE_PATH=./resume-engine

# Where compiled resumes are saved
TAILOR_OUT_ROOT=./output/tailored-resumes

# ── Ollama (local LLM) ───────────────────────────────────────────────────────
# Recommended model: gemma3:12b  (qwen3 truncates under JSON schema)
OLLAMA_MODEL=gemma3:12b
OLLAMA_HOST=127.0.0.1

# Shared secret between the tailor sidecar and the app (generate randomly)
TAILOR_TOKEN=

# Public cloudflared tunnel URL → localhost:8787 (for hosted UI → local tailor)
# TAILOR_ORIGIN=https://tailor-relay.yourdomain.com

# ── Job scraper ──────────────────────────────────────────────────────────────
# LinkedIn credentials (stored locally, never sent anywhere)
LINKEDIN_ENABLED=true
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Cloudflare (optional — only if self-hosting frontend on CF Pages) ────────
# CF_ACCOUNT_ID=
# CF_API_TOKEN=
# D1_DATABASE_ID=
# JWT_SECRET=                  # random 32+ char string
