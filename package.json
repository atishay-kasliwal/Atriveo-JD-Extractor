{
  "name": "atriveo-jd-extractor",
  "version": "1.0.0",
  "description": "Open-source job search platform. Self-hosted, local-first, LLM-powered.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config app/vite.config.ts",
    "build": "tsc -b && vite build --config app/vite.config.ts",
    "preview": "vite preview --config app/vite.config.ts",

    "server:dev": "tsx watch server/index.ts",
    "server:build": "tsc -p server/tsconfig.json && node server/dist/index.js",

    "tailor:prod": "node sidecar/tailor-server.mjs",
    "tailor:worker": "node sidecar/tailor-worker.mjs",

    "pipeline:install": "bash scripts/install-launchagents.sh",
    "pipeline:install:linux": "bash scripts/install-systemd.sh",
    "pipeline:status": "node scripts/check-services.mjs",

    "feed:sync": "node scripts/sync-feed.mjs",
    "resume:sync": "node scripts/sync-resume-queue.mjs",

    "deploy:pages": "wrangler pages deploy dist --project-name atriveo",
    "deploy:openshift": "bash deploy/openshift/deploy.sh",

    "db:migrate:d1": "wrangler d1 execute atriveo-auth --file=migrations/d1/0001_init.sql",
    "db:migrate:pg": "node scripts/migrate-postgres.mjs",
    "db:migrate:mongo": "node scripts/migrate-mongo.mjs",

    "setup": "bash scripts/setup.sh",
    "lint": "eslint app/src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "pg": "^8.12.0",
    "mongoose": "^8.4.0",
    "jose": "^6.2.2",
    "zod": "^3.23.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.11.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@cloudflare/workers-types": "^4.20260409.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "tsx": "^4.16.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "wrangler": "^4.81.1"
  }
}
